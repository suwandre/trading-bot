# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# MongoDB (Optional for backtesting, required for production)
MONGODB_URI=mongodb://localhost:27017/trading-bot
MONGODB_ENABLED=false

# Binance API (OPTIONAL - only needed for private account data)
# For backtesting, API keys are NOT required (uses public market data)
# Leave empty for backtesting, only fill if you need account access
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=false

# MEXC API (for live trading)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here
MEXC_TESTNET=false

# Risk Management
MAX_TOTAL_EXPOSURE=10000
MAX_DAILY_LOSS=500
MAX_DRAWDOWN_PERCENT=20
EMERGENCY_STOP_ENABLED=true

# Backtesting
BACKTEST_CACHE_ENABLED=true
BACKTEST_CACHE_SIZE=1000

# WebSocket
WS_ENABLED=true
WS_HEARTBEAT_INTERVAL=30000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000
